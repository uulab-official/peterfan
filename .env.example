# PeterFan local release/signing settings.
# Copy to .env, fill local-only values, and keep .env out of git.

PETERFAN_BUNDLE_ID=kr.co.uulab.peterfan
PETERFAN_DAEMON_LABEL=kr.co.uulab.peterfan.daemon
PETERFAN_LOGIN_ITEM_LABEL=kr.co.uulab.peterfan.menubar

# Must be a Developer ID Application identity for distribution outside the Mac App Store.
# Example:
# PETERFAN_SIGN_IDENTITY="Developer ID Application: bonjin.app (TEAMID)"
PETERFAN_SIGN_IDENTITY=

# Recommended local notary setup:
# xcrun notarytool store-credentials peterfan-notary \
#   --apple-id you@example.com --team-id TEAMID --password app-specific-password
NOTARYTOOL_PROFILE=peterfan-notary

# Used by scripts/setup-macos-signing.sh csr.
APPLE_ID=
APPLE_TEAM_ID=
PETERFAN_CERT_COMMON_NAME="bonjin.app PeterFan Developer ID"
